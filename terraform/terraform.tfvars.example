project_id             = "your-gcp-project-id"
region                 = "asia-southeast1"
gcs_bucket_bank        = "clairvoyance-bank"
gcs_bucket_investments = "clairvoyance-investments"

# Set after first `docker build && docker push` (see deployment steps below)
pipeline_image         = ""

# API secrets — these are written to Secret Manager on `terraform apply`.
# Alternatively, leave blank here and set them manually via:
#   gcloud secrets versions add SECRET_NAME --data-file=-
anthropic_api_key      = ""
gemini_api_key         = ""
gemini_api_secret      = ""
tiger_id               = ""
tiger_account          = ""
tiger_private_key      = ""
ibkr_flex_token        = ""
ibkr_flex_query_id     = ""
